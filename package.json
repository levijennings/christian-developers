  "description": "Faith-Driven Tech Community & Job Board",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest",
    "test:unit": "vitest run --reporter=verbose",
